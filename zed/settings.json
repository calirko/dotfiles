{
  "format_on_save": "on",
  "formatter": "prettier",
  "agent": {
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5.3-codex",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "eager",
  },
  "project_panel": {
    "sort_mode": "files_first",
    "dock": "right",
    "auto_fold_dirs": false,
  },
  "minimap": {
    "show": "never",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "ui_font_size": 15,
  "buffer_font_size": 15,
  "ui_font_family": "JetBrainsMono Nerd Font",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "calirko",
  },
  "gutter": {
    "min_line_number_digits": 0,
  },
}
