# ── General ──────────────────────────────
max-visible=3
sort=-time
layer=overlay
anchor=top-right

# ── Appearance ───────────────────────────
background-color=#0e0e0e
text-color=#b0b0b0
border-size=0
border-radius=0
padding=15
margin=8,8
width=350
height=150
font=JetBrainsMono Nerd Font 11

# ── Icons ────────────────────────────────
icons=1
max-icon-size=48
icon-location=left

# ── Behavior ─────────────────────────────
default-timeout=5000
ignore-timeout=0
group-by=app-name
